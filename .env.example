# --------------------------------------------------
# Core application mode
# --------------------------------------------------
APP_CONFIG=production
FLASK_DEBUG=false
FLASK_RUN_HOST=0.0.0.0
FLASK_RUN_PORT=10000

# --------------------------------------------------
# Security
# --------------------------------------------------
SECRET_KEY=your_long_random_secret_key_here
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Lax
SESSION_REFRESH_EACH_REQUEST=false
WTF_CSRF_TIME_LIMIT_SECONDS=7200
WTF_CSRF_SSL_STRICT=true
PERMANENT_SESSION_LIFETIME_SECONDS=1209600
EMAIL_VERIFICATION_TOKEN_TTL_SECONDS=86400
PASSWORD_RESET_TOKEN_TTL_SECONDS=3600
PASSWORD_RESET_HELP_EMAIL=support@example.com
CHECK_EMAIL_DELIVERABILITY=true

# --------------------------------------------------
# Database
# --------------------------------------------------
DATABASE_URL=postgresql+psycopg://username:password@host:5432/database_name

# --------------------------------------------------
# Upload and storage limits
# --------------------------------------------------
MAX_CONTENT_LENGTH=52428800
MAX_SINGLE_UPLOAD_BYTES=26214400
TEMP_FILE_TTL_HOURS=24
SHARE_LINK_TTL_HOURS=24
UPLOAD_ROOT=/opt/render/project/src/uploads
OUTPUT_ROOT=/opt/render/project/src/outputs
CLOUD_ROOT=/opt/render/project/src/cloud
SCAN_ROOT=/opt/render/project/src/uploads/scanner
AUTO_TEMP_CLEANUP=true
AUTO_TEMP_CLEANUP_INTERVAL_MINUTES=60

# --------------------------------------------------
# Google OAuth (optional)
# --------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_DISCOVERY_URL=https://accounts.google.com/.well-known/openid-configuration
PUBLIC_BASE_URL=https://your-app-name.onrender.com

# --------------------------------------------------
# Admin access
# --------------------------------------------------
ADMIN_EMAIL=owner@example.com
ADMIN_ALLOWED_EMAILS=admin1@example.com,admin2@example.com
ADMIN_OWNER_EMAILS=owner@example.com
ADMIN_SUPPORT_EMAILS=support1@example.com,support2@example.com
ADMIN_SEED_EMAIL=owner@example.com
ADMIN_SEED_PASSWORD=change_this_admin_password

# --------------------------------------------------
# Payments
# --------------------------------------------------
PAYMENT_MODE=live
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here
RAZORPAY_CURRENCY=INR
RAZORPAY_CALLBACK_URL=https://your-app-name.onrender.com/billing/razorpay/callback
RAZORPAY_API_BASE=https://api.razorpay.com

# --------------------------------------------------
# Subscription pricing
# --------------------------------------------------
SUBSCRIPTION_PRICE_PROFILE=default
CUSTOM_DAILY_RATE_PAISE=100
CUSTOM_PLAN_MIN_DAYS=5
CUSTOM_PLAN_MAX_DAYS=365
EXPIRING_SOON_DAYS=7
COUPONS_ENABLED=true

# --------------------------------------------------
# Jobs / OCR / runtime behavior
# --------------------------------------------------
JOB_MAX_WORKERS=2
OCR_LANG=eng
TRANSLATION_PROVIDER=
AUTO_SEED_ON_STARTUP=false
TOOL_PLACEHOLDER_TARGET=1000

# --------------------------------------------------
# Security headers / CSP
# --------------------------------------------------
DISABLE_SECURITY_HEADERS=false
CSP_ALLOW_UNSAFE_INLINE=true

# --------------------------------------------------
# Optional billing settings destination override
# --------------------------------------------------
BILLING_SETTINGS_URL=

# --------------------------------------------------
# SMTP / email delivery (required for local email signup verification)
# --------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username_here
SMTP_PASSWORD=your_smtp_password_here
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# --------------------------------------------------
# Cloud integrations (optional)
# --------------------------------------------------
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=

# --------------------------------------------------
# API + webhook controls
# --------------------------------------------------
API_DEFAULT_RATE_LIMIT_PER_MINUTE=60
WEBHOOK_MAX_FAILURES=10
RATELIMIT_ENABLED=true
RATELIMIT_STORAGE_URI=memory://
RATELIMIT_HEADERS_ENABLED=true

# --------------------------------------------------
# Privacy defaults
# --------------------------------------------------
PRIVACY_DEFAULT_AUTO_DELETE_HOURS=24

# --------------------------------------------------
# Standalone admin_app.py (optional)
# --------------------------------------------------
ADMIN_SECRET_KEY=your_admin_secret_key_here
ADMIN_RUN_HOST=127.0.0.1
ADMIN_RUN_PORT=5050
ADMIN_DEBUG=false

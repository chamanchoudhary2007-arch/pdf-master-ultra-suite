APP_CONFIG=development
FLASK_DEBUG=true
FLASK_RUN_HOST=127.0.0.1
FLASK_RUN_PORT=5000

SECRET_KEY=change-this-to-a-strong-random-secret
DATABASE_URL=sqlite:///instance/pdfmaster_ultra.db
# Optional fallback key supported by app config:
# DATABASE_URI=postgresql+psycopg://username:password@host:5432/database_name
MAX_CONTENT_LENGTH=52428800
MAX_SINGLE_UPLOAD_BYTES=26214400
TEMP_FILE_TTL_HOURS=24

# Gmail SMTP (use App Password, not regular account password)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=your-16-char-google-app-password
MAIL_DEFAULT_SENDER=your-gmail@gmail.com
MAIL_SENDER_NAME=PDFMaster Security
MAIL_TIMEOUT_SECONDS=10
EMAIL_LOGO_URL=https://pdf-master-ultra-suite.onrender.com/static/images/logo.jpeg
PUBLIC_BASE_URL=https://pdf-master-ultra-suite.onrender.com
OTP_TTL_MINUTES=2
OTP_MAX_ATTEMPTS=5

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_DISCOVERY_URL=https://accounts.google.com/.well-known/openid-configuration
# Optional explicit callback URI (must match Google Console exactly):
# GOOGLE_REDIRECT_URI=https://your-app-name.onrender.com/auth/google-auth

# Separate admin panel app
ADMIN_EMAIL=pdfmasterultrasuite@gmail.com
ADMIN_ALLOWED_EMAILS=pdfmasterultrasuite@gmail.com
ADMIN_SEED_EMAIL=pdfmasterultrasuite@gmail.com
ADMIN_SEED_PASSWORD=change-this-strong-admin-password
ADMIN_SECRET_KEY=change-this-admin-secret
ADMIN_RUN_HOST=127.0.0.1
ADMIN_RUN_PORT=5050
ADMIN_DEBUG=true

RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_test_key_secret
RAZORPAY_CURRENCY=INR
# Optional: if empty, app will auto-build callback URL from current host.
RAZORPAY_CALLBACK_URL=

# Active pricing profile for subscription plans.
SUBSCRIPTION_PRICE_PROFILE=default

# Optional custom premium day plan controls
CUSTOM_DAILY_RATE_PAISE=100
CUSTOM_PLAN_MIN_DAYS=5
CUSTOM_PLAN_MAX_DAYS=365
EXPIRING_SOON_DAYS=7

# Phase 2 (keep false for now)
COUPONS_ENABLED=false
